<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <FrameLayout
        android:id="@+id/heroContainer"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/imgTripHeader"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:adjustViewBounds="true"
            android:src="@drawable/ic_travel_placeholder" />

        <View
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_gravity="bottom"
            android:background="@drawable/trip_gradient" />

        <ImageButton
            android:id="@+id/btnEditPhoto"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="end|top"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_menu_camera"
            android:contentDescription="Cambiar foto de viaje"
            android:elevation="4dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilTripTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_marginBottom="2dp"
            android:layout_marginHorizontal="16dp"
            app:hintEnabled="false"
            app:boxBackgroundMode="none"
            app:endIconMode="custom"
            app:endIconDrawable="@android:drawable/ic_menu_edit"
            app:endIconTint="@android:color/white"> <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etTripTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:paddingStart="4dp"
            android:text="Finde en Dublín"
            android:textColor="@android:color/white"
            android:textSize="26sp"
            android:textStyle="bold"
            android:inputType="textCapSentences"/>
        </com.google.android.material.textfield.TextInputLayout>
    </FrameLayout>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayoutTrip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:tabIndicatorColor="@color/primary_app"
        app:tabIndicatorFullWidth="false"
        app:tabSelectedTextColor="@color/primary_app"
        app:tabIconTint="@color/primary_app"
        app:layout_constraintTop_toBottomOf="@id/heroContainer"/>

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPagerTrip"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/tabLayoutTrip"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>