<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.TripPlanner" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/primary_app</item>
        <item name="colorPrimaryContainer">@color/primary_app</item>
        <item name="colorSecondary">@color/secondary_app</item>
        <item name="colorAccent">@color/secondary_app</item>
    </style>

    <style name="Theme.TripPlanner" parent="Base.Theme.TripPlanner" />

    <style name="Theme.TripPlanner.Splash" parent="Theme.SplashScreen">

        <item name="windowSplashScreenBackground">@color/primary_app</item>

        <item name="windowSplashScreenAnimatedIcon">@drawable/logo_con_margen</item>

        <item name="postSplashScreenTheme">@style/Theme.TripPlanner</item>

    </style>



</resources>